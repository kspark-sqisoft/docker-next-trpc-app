# DB (Docker Compose 기본값과 맞춤)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=board
DB_PASSWORD=board
DB_NAME=board

# Drizzle CLI 전용 (로컬에서 drizzle-kit 실행 시 선택)
# DATABASE_URL=postgresql://board:board@localhost:5432/board

# NextAuth.js (필수: 프로덕션에서는 강한 무작위 문자열)
# 생성 예: openssl rand -base64 32
NEXTAUTH_SECRET=dev_only_nextauth_secret_min_32_chars_long!!
# 앱 공개 URL (OAuth·쿠키·이메일 링크 등에 사용)
NEXTAUTH_URL=http://localhost:3000

# SSR/tRPC 절대 URL (Docker·프록시 환경에서 설정 권장)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# 업로드 루트 (미설정 시 프로젝트 루트의 uploads/)
# UPLOADS_DIR=/app/uploads

# 학습용: 게시판 무한 스크롤 "다음 페이지" tRPC 지연(ms). 0 이면 끔. 비우면 NODE_ENV=development 일 때만 800ms
# LIST_INFINITE_LEARNING_DELAY_MS=800
