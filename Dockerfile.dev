# 개발: 소스 볼륨 마운트 + next dev (핫 리로드)
FROM node:22-alpine
WORKDIR /app
RUN apk add --no-cache libc6-compat
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
EXPOSE 3000
ENV HOSTNAME=0.0.0.0
ENV NEXT_TELEMETRY_DISABLED=1
# Compose 와 함께 쓸 때도 기본값으로 두면 볼륨 마운트 환경에서 감시가 안정적임
ENV DOCKER_DEV=1
ENV WATCHPACK_POLLING=true
CMD ["sh", "-c", "npx drizzle-kit push --force && npm run dev:docker"]
